RewriteEngine On

# Map root to index.html
RewriteRule ^$ index.html [L]

# Map /home and /index to index.html
RewriteRule ^home$ index.html [L]
RewriteRule ^index$ index.html [L]

# Remove trailing slashes from URLs (moved after home/index to avoid loop if someone visits /home/)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [L,R=301]

# Map clean URLs to files in /pages (if the page exists)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/pages/$1.html -f
RewriteRule ^([^/]+)$ pages/$1.html [L]
